{
	"name": "@heyhuynhgiabuu/pi-diff",
	"version": "0.7.6",
	"description": "Shiki-powered terminal diff renderer for pi — syntax-highlighted, word-level diffs in split and unified views.",
	"keywords": [
		"diff",
		"pi",
		"pi-extension",
		"pi-package",
		"shiki",
		"syntax-highlighting",
		"terminal"
	],
	"homepage": "https://github.com/buddingnewinsights/pi-diff#readme",
	"bugs": {
		"url": "https://github.com/buddingnewinsights/pi-diff/issues"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"author": "huynhgiabuu",
	"repository": {
		"type": "git",
		"url": "https://github.com/buddingnewinsights/pi-diff.git"
	},
	"files": [
		"dist/",
		"media/",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"lint:fix": "biome check --fix src/",
		"test": "vitest run src --passWithNoTests",
		"test:watch": "vitest src --passWithNoTests"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.80.0",
		"@earendil-works/pi-tui": "^0.80.0",
		"@shikijs/cli": "^4.0.2",
		"diff": "^7.0.0",
		"xxhash-wasm": "^1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/diff": "^7.0.2",
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0",
		"vitest": "^4.0.18"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		]
	},
	"main": "./dist/index.js",
	"exports": {
		"default": "./dist/index.js"
	}
}
