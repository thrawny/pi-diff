{
  "name": "@heyhuynhgiabuu/pi-diff",
  "version": "0.6.6",
  "description": "Shiki-powered terminal diff renderer for pi — syntax-highlighted, word-level diffs in split and unified views.",
  "keywords": [
    "diff",
    "pi",
    "pi-extension",
    "pi-package",
    "shiki",
    "syntax-highlighting",
    "terminal"
  ],
  "homepage": "https://github.com/buddingnewinsights/pi-diff#readme",
  "bugs": {
    "url": "https://github.com/buddingnewinsights/pi-diff/issues"
  },
  "license": "MIT",
  "author": "huynhgiabuu",
  "repository": {
    "type": "git",
    "url": "https://github.com/buddingnewinsights/pi-diff.git"
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "dist/edit-guard.d.ts",
    "dist/edit-guard.d.ts.map",
    "dist/edit-guard.js",
    "dist/edit-guard.js.map",
    "dist/core/config.d.ts",
    "dist/core/config.d.ts.map",
    "dist/core/config.js",
    "dist/core/config.js.map",
    "dist/core/conflicts.d.ts",
    "dist/core/conflicts.d.ts.map",
    "dist/core/conflicts.js",
    "dist/core/conflicts.js.map",
    "dist/core/diff.d.ts",
    "dist/core/diff.d.ts.map",
    "dist/core/diff.js",
    "dist/core/diff.js.map",
    "dist/core/replace.d.ts",
    "dist/core/replace.d.ts.map",
    "dist/core/replace.js",
    "dist/core/replace.js.map",
    "dist/core/resolve-lines.d.ts",
    "dist/core/resolve-lines.d.ts.map",
    "dist/core/resolve-lines.js",
    "dist/core/resolve-lines.js.map",
    "dist/review/git.d.ts",
    "dist/review/git.d.ts.map",
    "dist/review/git.js",
    "dist/review/git.js.map",
    "dist/review/hunk-preview.d.ts",
    "dist/review/hunk-preview.d.ts.map",
    "dist/review/hunk-preview.js",
    "dist/review/hunk-preview.js.map",
    "media/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "test": "vitest run src --passWithNoTests",
    "test:watch": "vitest src --passWithNoTests"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@earendil-works/pi-tui": "^0.79.0",
    "@heyhuynhgiabuu/pi-diff": "0.6.6",
    "@shikijs/cli": "^4.0.2",
    "diff": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "main": "./dist/index.js",
  "exports": {
    "default": "./dist/index.js"
  }
}
